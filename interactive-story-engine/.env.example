# ─────────────────────────────────────────────────────────────
# LLM Backend — choose one: "grok", "ollama", or "watsonx"
# ─────────────────────────────────────────────────────────────
LLM_BACKEND=grok

# ── Grok / xAI (FREE — recommended) ──────────────────────────
# 1. Go to https://console.x.ai
# 2. Sign up (free) → API Keys → Create key
# 3. Paste your key below
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-3-mini
GROK_BASE_URL=https://api.x.ai/v1

# ── Ollama (local, FREE, no account) ─────────────────────────
# 1. Install: https://ollama.com/download
# 2. Run:     ollama pull granite3.1-dense:2b
# Then set LLM_BACKEND=ollama above
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite3.1-dense:2b

# ── IBM watsonx.ai (cloud) ────────────────────────────────────
# Only needed when LLM_BACKEND=watsonx
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# ─────────────────────────────────────────────────────────────
APP_ENV=development
